import yaml

def extract_kde_elements(chunk_text):
  """Extracts key data elements from a text chunk and returns a YAML representation."""
  try:
    data = yaml.safe_load(chunk_text)
    return data
  except yaml.YAMLError as e:
    print(f"Error parsing YAML: {e}")
    return None

